{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "state-yml.schema.json",
  "title": "ProjectPal state.yml",
  "description": "Schema for .projectpal/state.yml — per-session, per-repo project state. Connector status snapshots include last_failure_at (ISO-8601 | null). Absence of this field in existing files must be treated as null at read time — never error.",
  "type": "object",
  "properties": {
    "repo_slug": { "type": "string" },
    "repo_root_hint": { "type": "string" },
    "current_project": { "type": ["string", "null"] },
    "current_phase": { "type": ["integer", "null"] },
    "complexity_domain": { "type": ["string", "null"] },
    "last_session": { "type": ["string", "null"] },
    "resume_source": { "type": ["string", "null"] },
    "synced_at": { "type": ["string", "null"] },
    "artifacts_dir": { "type": ["string", "null"] },
    "bridge_summary": { "type": ["string", "null"] },
    "last_artifact_ref": { "type": ["string", "null"] },
    "partial_context": {
      "type": ["object", "null"],
      "properties": {
        "complete": { "type": "boolean" },
        "readiness": { "type": "object" }
      }
    },
    "thread_orchestration": {
      "type": ["object", "null"],
      "properties": {
        "active_thread_id": { "type": ["string", "null"] },
        "threads": { "type": "array" },
        "execution_paths": { "type": "array" },
        "connector_status_snapshots": {
          "type": "array",
          "items": { "$ref": "#/definitions/ConnectorStatusSnapshot" }
        },
        "delegation_tasks": { "type": "array" },
        "fallback_records": { "type": "array" }
      }
    },
    "next_steps": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "definitions": {
    "ConnectorStatusSnapshot": {
      "type": "object",
      "description": "Point-in-time availability snapshot for a connector. last_failure_at is new in v1.1 — treat absence as null for backward compatibility.",
      "required": ["connector_identity", "auth_state", "availability_state", "quota_state", "checked_at"],
      "properties": {
        "connector_identity": { "type": "string" },
        "auth_state": {
          "type": "string",
          "enum": ["available", "missing", "expired", "denied", "unknown"]
        },
        "availability_state": {
          "type": "string",
          "enum": ["available", "degraded", "unavailable", "unknown"]
        },
        "last_failure_reason": {
          "oneOf": [
            { "type": "string", "enum": ["none", "quota_exhausted", "connector_exhausted", "auth_failure", "runtime_error", "unknown"] },
            { "type": "null" }
          ]
        },
        "last_failure_at": {
          "oneOf": [
            { "type": "string", "format": "date-time" },
            { "type": "null" }
          ],
          "description": "ISO-8601 timestamp of the most recent failure. Null if no failure. Absent in legacy files — treat as null."
        },
        "quota_state": { "type": "string" },
        "checked_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
