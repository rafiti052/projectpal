#!/usr/bin/env bash
# bin/pp-compress вЂ” PostToolUse compression hook for ProjectPal
#
# Intercepts large Read outputs and injects a compressed summary into context,
# preventing expensive re-reads from bloating the session token count.
#
# Wired in .claude/settings.local.json as a PostToolUse hook on the Read tool.
# Cache lives in .projectpal/cache/ (gitignored), keyed by filepath + mtime.

set -euo pipefail

THRESHOLD_WORDS=400
CACHE_DIR=".projectpal/cache"

# в”Ђв”Ђ Read stdin into tempfile (avoids zsh echo mangling JSON escape sequences) в”Ђ
TMPFILE=$(mktemp)
trap 'rm -f "$TMPFILE"' EXIT
cat > "$TMPFILE"

# в”Ђв”Ђ Validate JSON; bail silently on malformed input в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
jq empty "$TMPFILE" 2>/dev/null || exit 0

# в”Ђв”Ђ Only handle Read tool в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
TOOL_NAME=$(jq -r '.tool_name // empty' "$TMPFILE")
[ "$TOOL_NAME" = "Read" ] || exit 0

# в”Ђв”Ђ Extract file path в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
FILE_PATH=$(jq -r '.tool_input.file_path // empty' "$TMPFILE")
[ -n "$FILE_PATH" ] || exit 0
[ -f "$FILE_PATH" ] || exit 0

# в”Ђв”Ђ Extract content (handles string or structured tool_response) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
CONTENT=$(jq -r '
  .tool_response |
  if type == "string" then .
  elif type == "object" then
    (.content? // []) | map(select(.type == "text") | .text) | join("\n")
  else empty
  end
' "$TMPFILE")
[ -n "$CONTENT" ] || exit 0

# в”Ђв”Ђ Threshold check в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
WORD_COUNT=$(printf '%s' "$CONTENT" | wc -w | tr -d ' ')
[ "$WORD_COUNT" -ge "$THRESHOLD_WORDS" ] || exit 0

# в”Ђв”Ђ Cache setup в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
mkdir -p "$CACHE_DIR"
CACHE_KEY=$(printf '%s' "$FILE_PATH" | md5 -q 2>/dev/null \
  || printf '%s' "$FILE_PATH" | md5sum | cut -d' ' -f1)
CACHE_FILE="$CACHE_DIR/${CACHE_KEY}.md"
FILE_MTIME=$(stat -f %m "$FILE_PATH" 2>/dev/null \
  || stat -c %Y "$FILE_PATH" 2>/dev/null \
  || echo "0")

# в”Ђв”Ђ Cache hit в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
if [ -f "$CACHE_FILE" ]; then
  CACHED_MTIME=$(head -1 "$CACHE_FILE" | grep -oE 'mtime:[0-9]+' | cut -d: -f2 || true)
  if [ "$CACHED_MTIME" = "$FILE_MTIME" ]; then
    COMPRESSED_WORDS=$(head -1 "$CACHE_FILE" | grep -oE 'compressed:[0-9]+' | cut -d: -f2 || echo "?")
    printf 'рџ“¦ pp-compress [warm] %s вЂ” %sw в†’ %sw (no re-read needed)\n\n' \
      "$(basename "$FILE_PATH")" "$WORD_COUNT" "$COMPRESSED_WORDS"
    tail -n +3 "$CACHE_FILE"
    exit 0
  fi
fi

# в”Ђв”Ђ Compress: headers + first content line under each в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
SUMMARY=$(printf '%s' "$CONTENT" | awk '
  /^#{1,4} / {
    pending = $0
    found_content = 0
    next
  }
  pending != "" && /^[^[:space:]#]/ && NF > 0 && !found_content {
    print pending
    print $0
    print ""
    pending = ""
    found_content = 1
    next
  }
  pending != "" && /^[[:space:]]*$/ { next }
  pending != "" {
    print pending
    print ""
    pending = ""
    found_content = 0
  }
  END { if (pending != "") print pending }
')

# Fallback: if no markdown headers found (e.g. YAML), take first 50 lines
if [ -z "$(printf '%s' "$SUMMARY" | tr -d '[:space:]')" ]; then
  SUMMARY=$(printf '%s' "$CONTENT" | head -50)
fi

COMPRESSED_WORDS=$(printf '%s' "$SUMMARY" | wc -w | tr -d ' ')

# в”Ђв”Ђ Write cache в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
{
  printf '<!-- mtime:%s original:%s compressed:%s source:%s -->\n\n' \
    "$FILE_MTIME" "$WORD_COUNT" "$COMPRESSED_WORDS" "$FILE_PATH"
  printf '%s\n' "$SUMMARY"
} > "$CACHE_FILE"

# в”Ђв”Ђ Output в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
printf 'рџ“¦ pp-compress [saved] %s вЂ” %sw в†’ %sw\n\n' \
  "$(basename "$FILE_PATH")" "$WORD_COUNT" "$COMPRESSED_WORDS"
printf '%s\n' "$SUMMARY"
